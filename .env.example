# Database (port 5433 — docker-compose maps host 5433 → container 5432)
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/dsa_platform

# Redis
REDIS_URL=redis://localhost:6379

# Auth0
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_AUDIENCE=https://api.algoarena.com
AUTH0_CLIENT_ID=your-client-id
AUTH0_CLIENT_SECRET=your-client-secret
AUTH0_SECRET=a-long-random-string-for-session-encryption
AUTH0_BASE_URL=http://localhost:3000
AUTH0_ISSUER_BASE_URL=https://your-tenant.us.auth0.com

# API
API_PORT=3001
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=ws://localhost:3001

# Judge
JUDGE_DOCKER_SOCKET=/var/run/docker.sock
JUDGE_MAX_CPU=1
JUDGE_MAX_MEMORY_MB=256
JUDGE_TIMEOUT_MS=10000
JUDGE_MAX_OUTPUT_BYTES=1048576
