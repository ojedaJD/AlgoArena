{
	"name": "AlgoArena Dev",
	"image": "mcr.microsoft.com/devcontainers/typescript-node:4-24-trixie",

	"features": {
		"ghcr.io/devcontainers/features/postgresql:1": {
			"version": "16"
		},
		"ghcr.io/itsmechlark/features/redis-server:1": {}
	},

	"forwardPorts": [3000, 3001, 5432, 6379],

	"postCreateCommand": "make setup",

	"customizations": {
		"vscode": {
			"extensions": ["Prisma.prisma"]
		}
	}
}
