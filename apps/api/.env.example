# Application
NODE_ENV=development
API_PORT=3001

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/dsa_platform?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# Auth0
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_AUDIENCE=https://api.algoarena.com

# Judge (Docker-based code execution)
JUDGE_DOCKER_SOCKET=/var/run/docker.sock
JUDGE_MAX_CPU=1
JUDGE_MAX_MEMORY_MB=256
JUDGE_TIMEOUT_MS=10000
